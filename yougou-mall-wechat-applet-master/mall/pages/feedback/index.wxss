/* pages/feedback/index.wxss */

page{
    background-color: #eeeeee;
}

.fb_main{
    padding: 20rpx;
    color: #666;
}

.fb_tips{
    display: flex;
    flex-wrap: wrap;
}


text{
    width: 30%;
    padding: 10rpx;
    text-align: center;
    background-color: #fff;
    margin: 20rpx 10rpx;
}

.fb_content{
    background-color: #fff;
    margin-top: 20rpx;
}

textarea{
    padding: 10rpx;
}

.fb_tool{
    display: flex;
    flex: wrap;
    padding-bottom: 30rpx;
}

.fb_tool button{
    width: 90rpx;
    height: 90rpx;
    font-size: 60rpx;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 20rpx;
    margin-left: 20rpx;
    color: #ccc;
}

.form_btn_wrap{
    margin-top: 20rpx;
    display: flex;
    justify-content: flex-end;
    
}

.form_btn_wrap button{
    margin: 0;
    width: 30%;
    font-size: 35rpx;
}

.up_img_item{
    margin-top: 20rpx;
    margin-left: 20rpx;
}