.order_item{
    padding: 20rpx;
    border-bottom: 1px solid #ccc;
    color: #666;
}

.order_no_row{
    display: flex;
    padding: 10rpx 0;
    justify-content: space-between;
}

.order_price_row{
    padding: 10rpx 0;
    display: flex;
    justify-content: space-between;
}

.order_price_value{
    color: var(--themeColor);
    font-size: 35rpx;
    font-weight: 600;
}


.order_time_row{
    padding: 10rpx 0;
    display: flex;
    justify-content: space-between;
}